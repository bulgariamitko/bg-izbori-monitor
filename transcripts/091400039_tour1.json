    {
      "start": 2031.08,
      "end": 2032.09,
      "text": "Надпис."
    },
    {
      "start": 2032.29,
      "end": 2033.33,
      "text": "Е, е, е."
    },
    {
      "start": 2074.14,
      "end": 2080.94,
      "text": "От там надолу почитете какво трябва да се сложи."
    },
    {
      "start": 2080.94,
      "end": 2086.22,
      "text": "Червновата на протоколите."
    },
    {
      "start": 2086.22,
      "end": 2090.22,
      "text": "Връзваш ги с едно канапче и от това пише."
    },
    {
      "start": 2090.22,
      "end": 2093.22,
      "text": "Ако не може да го правите..."
    },
    {
      "start": 2093.22,
      "end": 2097.22,
      "text": "Дай канапче ще нас вижда натиска и пахаме."
    },
    {
      "start": 2097.22,
      "end": 2108.54,
      "text": "Може да пише за облакама."
    },
    {
      "start": 2108.54,
      "end": 2110.54,
      "text": "Айде, тръгваме."
    },
    {
      "start": 2277.42,
      "end": 2279.42,
      "text": "Добре."
