    {
      "start": 2391.15,
      "end": 2393.15,
      "text": "Ами, какво ще беше?"
    },
    {
      "start": 2393.15,
      "end": 2395.15,
      "text": "Тези не ще правят."
    },
    {
      "start": 2395.15,
      "end": 2397.15,
      "text": "Да, но Бог ще се общава."
    },
    {
      "start": 2397.15,
      "end": 2399.15,
      "text": "Това че не трябва."
    },
    {
      "start": 2399.15,
