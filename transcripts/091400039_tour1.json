      "text": "Иде от му."
    },
    {
      "start": 2502.81,
      "end": 2504.81,
      "text": "Че е Омзън, че е Омзън."
    },
    {
      "start": 3115.32,
      "end": 3153.45,
      "text": "11 имаш, 1 на 0."
