    {
      "start": 1921.32,
      "end": 1923.86,
      "text": "Какво ме виждате?"
    },
    {
      "start": 1926.18,
      "end": 1932.18,
      "text": "Пакет с нарпис. Харчийни бюлетини намерени в избирателната кучия."
    },
    {
      "start": 1932.18,
      "end": 1939.18,
      "text": "Всичко общо пише пакет с нарпис. Харчийни бюлетини намерени в избирателната кучия."
    },
    {
      "start": 1939.18,
      "end": 1940.18,
      "text": "А, и да ма са..."
    },
    {
      "start": 1940.18,
      "end": 1942.18,
      "text": "Наши заедни?"
    },
    {
      "start": 1942.18,
      "end": 1953.18,
      "text": "Не вижда такова нещо в белия чувак. Пише пакет с напис. Хърчени бюлетини, намерени в избирателното куче."
    },
    {
      "start": 1953.18,
      "end": 1961.4,
      "text": "Толкова са. Питах я аз, аз не са вънкъде. Защо трябва да ги опърваме? Те са на едно място, това ще се зависти."
    },
    {
      "start": 1961.4,
      "end": 1964.4,
      "text": "Къде е това решмо?"
    },
    {
      "start": 1964.4,
      "end": 1967.4,
      "text": "Пишеш това и се възмираш старта."
    },
    {
      "start": 1967.4,
      "end": 1968.32,
      "text": "Най-доброше."
    },
    {
      "start": 1968.7,
      "end": 1969.38,
      "text": "Привет, Ви."
    },
    {
      "start": 1969.94,
      "end": 1970.6,
      "text": "Красиво е да е."
    },
    {
      "start": 1970.98,
      "end": 1971.7,
      "text": "Къде пишеш?"
    },
    {
      "start": 1971.7,
      "end": 1973.62,
      "text": "За твете, какво ще е?"
    },
    {
      "start": 1973.86,
      "end": 1974.54,
      "text": "Не възможно."
    },
    {
      "start": 1975.98,
      "end": 1976.48,
      "text": "Това е това."
    },
    {
      "start": 1977.08,
      "end": 1978.98,
      "text": "Това е твете."
    },
    {
      "start": 1979.84,
      "end": 1980.54,
      "text": "Твете и прик."
    },
    {
      "start": 1980.74,
      "end": 1982.66,
      "text": "Да, че не дочек, нещо си."
    },
    {
      "start": 1983.12,
      "end": 1984.74,
      "text": "На страница 11 садя."
    },
    {
      "start": 1985.22,
      "end": 1990.08,
      "text": "Поставихме, бе, чова пакет с нами с бюлетини извън избирателното кутие."
    },
    {
      "start": 1990.16,
      "end": 1993.72,
      "text": "Пакет с нами с артини бюлетини намерени с избирателното кутие."
    },
    {
      "start": 1993.9,
      "end": 1997.28,
      "text": "Садя си бюлетини заедно, упаковани."
    },
    {
      "start": 1997.28,
      "end": 2003.84,
      "text": "Долу гледай там, в прик, с надпис, номер 3."
    },
    {
      "start": 2004.74,
      "end": 2005.54,
      "text": "Нали не може да го пишем?"
    },
    {
      "start": 2005.54,
      "end": 2007.36,
      "text": "Ти жа насик, прочетете."
    },
    {
      "start": 2007.36,
      "end": 2010.88,
      "text": "Трябва да ги упакуваме в една харчия, нищо друго не пише."
    },
    {
      "start": 2011.42,
      "end": 2012.26,
      "text": "Аз не е какво."
    },
    {
      "start": 2012.26,
      "end": 2013.82,
      "text": "А, по-отдобро може, така няма."
    },
    {
      "start": 2013.82,
      "end": 2016.34,
      "text": "А, по-добро, но бобчета ги сливаме на една стойка."
    },
    {
      "start": 2016.56,
      "end": 2017.32,
      "text": "Е, е така."
