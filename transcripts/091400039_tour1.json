    {
      "start": 2303.58,
      "end": 2305.58,
      "text": "Не още не чернувата работа."
    },
    {
      "start": 2305.58,
      "end": 2317.75,
      "text": "Аз ще ти пиша по къде си смятам."
    },
    {
      "start": 2317.75,
      "end": 2321.8,
      "text": "Така, сега какво искаш?"
    },
    {
      "start": 2321.8,
      "end": 2323.8,
      "text": "Пишеме ли от среща?"
    },
    {
      "start": 2323.8,
      "end": 2325.8,
      "text": "Пишем срещата."
    },
    {
      "start": 2325.8,
      "end": 2329.8,
      "text": "Домесцифри 2255. Пишете."
    },
    {
      "start": 2329.8,
      "end": 2333.8,
      "text": "Тук също. С преференция има."
    },
    {
      "start": 2333.8,
      "end": 2337.8,
      "text": "Тук ще пописваме това кабелетините."
    },
    {
      "start": 2337.8,
      "end": 2341.8,
      "text": "Пишете си ето тук."
    },
    {
      "start": 2341.8,
      "end": 2345.8,
      "text": "Пишете си, че би да."
    },
    {
      "start": 2345.8,
      "end": 2349.8,
      "text": "Ако има една, как пишеш тука и тука кака го пишеш."
    },
    {
      "start": 2349.8,
      "end": 2353.86,
      "text": "Чакайте ми да ви покажа."
    },
    {
      "start": 2353.86,
      "end": 2358.86,
      "text": "Ти не виждаш. Сега. Произвел судебни листини без подземляване на члените си."
    },
    {
      "start": 2358.86,
      "end": 2359.86,
      "text": "Да речем."
    },
    {
      "start": 2359.86,
      "end": 2361.86,
      "text": "Подпис, подпис."
