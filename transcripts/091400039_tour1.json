      "end": 2369.86,
      "text": "Пишеш тука 100 и тука пишеш."
    },
    {
      "start": 2369.86,
      "end": 2377.86,
      "text": "Дайте ми 3, 2, 3, 2 и финален отчет."
    },
    {
      "start": 2377.86,
      "end": 2382.86,
      "text": "Аз иска да подписвам ли от гражданите, аз ще ме питаш за да правя."
