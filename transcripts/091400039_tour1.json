    },
    {
      "start": 2432.1,
      "end": 2433.1,
      "text": "Затяло българството."
    },
    {
      "start": 2433.1,
      "end": 2435.51,
      "text": "Багай клип номер 2 си най-българско."
    },
    {
      "start": 2444.71,
      "end": 2447.71,
      "text": "Ще ни борда на ръцвюрси."
    },
    {
      "start": 2447.71,
      "end": 2450.71,
      "text": "Номер 2 си, номер 2 си."
    },
    {
      "start": 2450.71,
      "end": 2453.71,
      "text": "Иде от държава и има нормалната..."
    },
    {
