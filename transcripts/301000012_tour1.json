  "segments": [
    {
      "start": 0.27,
      "end": 2.3,
      "text": "Добре."
    },
    {
      "start": 4.82,
      "end": 6.82,
      "text": "Да, да, да, няма проблеми, нали?"
    },
    {
      "start": 6.82,
      "end": 10.64,
      "text": "Това е най-важното."
    },
    {
      "start": 10.64,
      "end": 13.76,
      "text": "Иде, всичко да се вижда тук."
    },
    {
      "start": 13.76,
      "end": 15.76,
      "text": "Къде ще се тъпи?"
    },
    {
      "start": 15.76,
      "end": 19.14,
      "text": "Всичко."
    },
    {
      "start": 19.14,
      "end": 32.4,
      "text": "От далечина."
    },
    {
      "start": 35.2,
      "end": 37.87,
      "text": "Редко това."
    },
    {
      "start": 37.87,
      "end": 39.87,
      "text": "Редко."
    },
    {
      "start": 39.87,
      "end": 43.34,
      "text": "Така."
    },
    {
      "start": 43.34,
      "end": 45.34,
      "text": "Мисля, че се вижда всичко."
    },
    {
      "start": 45.34,
      "end": 49.68,
      "text": "Ама ти го тръгаш."
    },
    {
      "start": 49.68,
      "end": 52.96,
      "text": "Да, тебе да."
    },
    {
      "start": 52.96,
      "end": 58.67,
      "text": "Ето, надо се разпределяване."
    },
    {
      "start": 58.67,
      "end": 408.93,
      "text": "Добре."
    },
    {
      "start": 408.93,
      "end": 757.84,
      "text": "Стръпнете маса."
    },
    {
      "start": 1848.67,
      "end": 1850.9,
      "text": "Нещо."
    },
    {
      "start": 1850.9,
      "end": 1852.9,
      "text": "Бледна е, но даже така."
    },
    {
      "start": 1852.9,
      "end": 1865.14,
      "text": "Млади сме."
    },
    {
      "start": 1865.14,
      "end": 2641.41,
      "text": "Тези някакви слабе."
    },
    {
      "start": 2641.41,
      "end": 3815.38,
      "text": "Къде ма стоят?"
    },
    {
      "start": 3815.38,
      "end": 6938.62,
      "text": "Ето ги написахте, може ли да се снимат?"
    },
    {
      "start": 6938.62,
      "end": 7137.52,
      "text": "Пайсет."
    },
    {
      "start": 7137.52,
      "end": 8264.8,
      "text": "Нека, няма."
    },
    {
      "start": 8264.8,
      "end": 8269.1,
      "text": "Аз трябва да вземам."
    },
    {
      "start": 8269.1,
      "end": 8827.81,
      "text": "Че ме замесваш, брат, да трябва да ме сметам?"
    },
    {
      "start": 8827.81,
      "end": 8830.03,
      "text": "Айде, човек."
    },
    {
      "start": 8830.03,
      "end": 8844.9,
      "text": "Той ще прави си път 6."
    },
    {
      "start": 8844.9,
      "end": 8921.52,
      "text": "Оси и тей."
    },
    {
      "start": 8921.52,
      "end": 8923.52,
      "text": "Трябва да чуя дърво."
    },
    {
      "start": 8923.52,
      "end": 8925.52,
      "text": "Хайф на ебаха."
    }
  ],
