      "start": 6839.88,
      "end": 6842.01,
      "text": "115. Една."
    },
    {
      "start": 6842.01,
      "end": 6851.53,
      "text": "116. Една."
    },
    {
      "start": 6851.53,
      "end": 6855.54,
      "text": "Сега не са така."
    },
    {
      "start": 6855.54,
      "end": 6904.87,
      "text": "32. 31. преференция."
    },
    {
      "start": 6904.87,
      "end": 6906.87,
      "text": "Сега сега сега трябва да ме обичаме."
    },
    {
      "start": 6906.87,
      "end": 6908.87,
      "text": "Има не да ставаме ли да се обираме?"
    },
    {
      "start": 6908.87,
      "end": 6911.32,
      "text": "Нищо не става."
    },
    {
      "start": 6911.32,
      "end": 6924.97,
      "text": "Още съвреж. Знаеш ли?"
    },
    {
      "start": 6924.97,
      "end": 6926.97,
      "text": "Им тогава, им тогава, когато правя това, това си ще се тръгне."
    },
    {
      "start": 6926.97,
      "end": 6928.97,
      "text": "Ти ще се тръгнеш сега 20 минути по-рано,"
    },
    {
      "start": 6928.97,
      "end": 6930.97,
      "text": "ние ще ти кажем, че четири часа да прочим там."
    },
    {
      "start": 6930.97,
      "end": 6946.57,
      "text": "Да."
    },
    {
      "start": 6946.57,
      "end": 6948.57,
      "text": "Сега всички, че преференцият има, да ги смятнат да ли отговарят на броя на"
    },
    {
      "start": 6948.57,
      "end": 6953.74,
      "text": "конфликта."
    },
    {
      "start": 6953.74,
      "end": 7177.4,
      "text": "Не, аз ще ги гледам."
    },
    {
      "start": 7177.4,
      "end": 7782.79,
      "text": "Ти ще оставя тук, ако ти ще..."
    },
    {
      "start": 7782.79,
      "end": 7807.32,
      "text": "Сложи това."
    },
    {
      "start": 7807.32,
      "end": 7809.32,
      "text": "Леки, че го засминят. Чакай, аз ще тя ще го върна."
    },
    {
      "start": 7809.32,
      "end": 7813.08,
      "text": "Ти ли ще ги сега върна?"
    },
    {
      "start": 7813.08,
      "end": 7815.5,
      "text": "Може да караме, някакви, че пред ми."
    },
    {
      "start": 7815.5,
      "end": 7819.51,
      "text": "Знам, карали са мои, може да пиша."
    },
    {
      "start": 7819.51,
      "end": 7821.86,
      "text": "Не мога да кажа, че това са луди."
    },
    {
      "start": 7821.86,
      "end": 7824.57,
      "text": "Куда ти кажа? Следва всичко казанието."
    },
    {
      "start": 7824.57,
      "end": 7855.3,
      "text": "После ви няма да ходите там."
    },
    {
      "start": 7855.3,
      "end": 7857.3,
      "text": "Суренкът ме пита да знам,"
    },
    {
      "start": 7857.3,
      "end": 7862.54,
      "text": "за какво така е написано."
    },
    {
      "start": 7862.54,
      "end": 7874.42,
      "text": "Не знам."
    },
    {
      "start": 7874.42,
      "end": 7876.42,
      "text": "Тук ще взема копия от протоколата."
    },
    {
      "start": 7876.42,
      "end": 7878.42,
      "text": "В списъка имената и нето качеството."
    },
    {
      "start": 7878.42,
      "end": 7880.42,
      "text": "Таблика какъв."
    },
    {
      "start": 7880.42,
      "end": 7882.42,
      "text": "Представител, застъпеници, членове."
    },
    {
      "start": 7882.42,
      "end": 7983.08,
      "text": "Представител."
    },
    {
      "start": 7983.08,
      "end": 7987.42,
      "text": "А, е представител, няма чак тоя, който е няма."
    },
    {
      "start": 7987.42,
      "end": 8346.25,
      "text": "Аз по 20 г."
    },
    {
      "start": 8346.25,
      "end": 8459.06,
      "text": "Малките са."
    },
    {
      "start": 8459.06,
      "end": 8461.06,
      "text": "Досидия... досидия... досидия..."
    },
    {
      "start": 8461.06,
      "end": 8728.38,
      "text": "Та отче..."
    },
    {
      "start": 8728.38,
      "end": 11353.06,
      "text": "Вече го спорят."
    },
    {
      "start": 11353.06,
      "end": 11782.17,
      "text": "Не знам."
    },
    {
      "start": 11782.17,
      "end": 12052.49,
      "text": "Те нещо ще остават."
    },
    {
      "start": 12052.49,
      "end": 12054.78,
      "text": "Айде да сакат."
    },
    {
      "start": 12054.78,
      "end": 12728.97,
      "text": "Не са като който са, но..."
    },
    {
      "start": 12728.97,
      "end": 13433.78,
      "text": "Нямаше му да ръцит."
    },
    {
      "start": 13433.78,
      "end": 13727.88,
      "text": "Не, не, не."
    },
    {
      "start": 13727.88,
      "end": 13729.88,
      "text": "Прибирай."
