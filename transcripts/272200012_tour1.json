    },
    {
      "start": 2377.69,
      "end": 2385.62,
      "text": "Тук е побеж. Тук няма посоча на партия,"
    },
    {
      "start": 2385.62,
      "end": 2389.8,
      "text": "има само преференция."
    },
    {
      "start": 2389.8,
      "end": 2398.79,
      "text": "Малко задръскано, ама да го посним ли, или?"
