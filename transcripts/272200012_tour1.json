    {
      "start": 2419.31,
      "end": 2422.31,
      "text": "Това е съвсем извън."
    },
    {
      "start": 2422.31,
      "end": 2436.54,
      "text": "За чайпини и 15."
    },
    {
      "start": 2436.54,
      "end": 2444.31,
