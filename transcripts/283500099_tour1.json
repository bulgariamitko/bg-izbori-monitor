    },
    {
      "start": 182.88,
      "end": 197.08,
      "text": "И за мене ще лома окно."
    },
    {
      "start": 197.08,
      "end": 198.24,
      "text": "Смятаме за действие."
    },
    {
      "start": 198.24,
      "end": 201.03,
      "text": "Двадесет и шест."
    },
    {
      "start": 201.63,
      "end": 203.59,
      "text": "С знак точка."
    },
    {
      "start": 212.13,
      "end": 213.29,
      "text": "Глаза си."
    },
    {
      "start": 215.67,
      "end": 215.97,
      "text": "Ими да."
    },
    {
      "start": 218.93,
      "end": 220.75,
      "text": "Четирсет и пет."
    },
    {
      "start": 223.56,
      "end": 229.85,
      "text": "Четирсет и пет."
    },
    {
      "start": 229.85,
      "end": 231.05,
      "text": "Това се вижда по..."
    },
    {
      "start": 231.05,
      "end": 236.22,
      "text": "Двадесет и девет гласа."
    },
    {
      "start": 238.09,
      "end": 242.62,
      "text": "Трима. Четири."
    },
    {
      "start": 244.44,
      "end": 247.89,
      "text": "Пет. Шест."
    },
    {
      "start": 248.29,
      "end": 255.02,
      "text": "Двадесет и две се протива."
    },
    {
      "start": 255.24,
      "end": 256.08,
      "text": "Няма гласа ли?"
    },
    {
      "start": 257.14,
      "end": 259.14,
      "text": "За партия номер двадесет"
    },
    {
      "start": 259.14,
      "end": 261.14,
      "text": "партия на Зеленки няма басоли."
    },
    {
      "start": 261.14,
      "end": 265.84,
      "text": "За партия 2 с народния сновид 24 няма басоли."
    },
    {
      "start": 265.84,
      "end": 271.6,
      "text": "Никога. Един брой."
    },
    {
      "start": 271.6,
      "end": 283.02,
      "text": "Значи да пишете за 10 още."
    },
    {
      "start": 283.02,
      "end": 285.09,
      "text": "Пет."
    },
    {
      "start": 285.09,
      "end": 287.09,
      "text": "Аз ще ви секс."
    },
    {
      "start": 287.09,
      "end": 289.09,
      "text": "Това същото и се помни на ставица."
    },
    {
      "start": 289.09,
      "end": 291.09,
      "text": "Туна ви беше 4 туна хикс."
    },
    {
      "start": 291.09,
      "end": 293.09,
      "text": "Та ще остане 2."
    },
    {
      "start": 293.09,
      "end": 295.09,
      "text": "Има и смърт на брадната са."
    },
    {
      "start": 295.09,
      "end": 297.09,
      "text": "Може да изправя да следващия басол."
    },
    {
      "start": 297.09,
      "end": 302.95,
      "text": "Да, но трях им калма да я справя. Никой не знае какво е реално за дете."
    },
    {
      "start": 302.95,
      "end": 306.62,
      "text": "Освен този, който си го възможност."
    },
    {
      "start": 306.62,
      "end": 311.62,
      "text": "Положено е ясно старание да се бъде ясен Бог, за неприятен човек."
    },
    {
      "start": 311.62,
      "end": 314.62,
      "text": "За мен е вредно."
    },
    {
      "start": 314.62,
      "end": 316.62,
      "text": "Това е моето мнение."
    },
    {
      "start": 316.62,
      "end": 321.31,
      "text": "Както реши."
    },
    {
      "start": 321.31,
      "end": 324.31,
      "text": "За конкретен човек, конкретна партия си го."
    },
    {
      "start": 324.31,
      "end": 328.9,
      "text": "Да."
    },
    {
      "start": 328.9,
      "end": 341.94,
      "text": "Напредете го."
    },
    {
      "start": 341.94,
      "end": 390.38,
      "text": "Дайте да те сравним."
    },
    {
      "start": 390.38,
      "end": 411.83,
      "text": "Той реално така е направил и още два пъти."
    },
    {
      "start": 412.41,
      "end": 414.09,
      "text": "Никой не е казал, че трябва да се вярва."
    },
    {
      "start": 418.99,
      "end": 441.41,
      "text": "Това два пъти просто..."
    },
    {
      "start": 442.47,
      "end": 445.1,
      "text": "Искаш ли си..."
    },
    {
      "start": 446.38,
      "end": 447.18,
      "text": "Които?"
    },
    {
      "start": 449.7,
      "end": 450.16,
      "text": "Добре, да."
    },
    {
      "start": 456.22,
      "end": 469.26,
      "text": "Няма."
    },
    {
      "start": 469.82,
      "end": 482.9,
      "text": "Аз нямам."
    },
    {
      "start": 492.34,
      "end": 493.66,
      "text": "Момичето, момиче, не ти."
    },
    {
      "start": 495.16,
      "end": 496.36,
      "text": "Ама не казваш, дай ли не."
    },
    {
      "start": 496.36,
      "end": 501.36,
      "text": "Дай се ставим с патухол за тази бюлетина и да вземем решението."
    },
    {
      "start": 501.36,
      "end": 505.22,
      "text": "Не, ще вземем и имаме решението."
    },
    {
      "start": 505.22,
      "end": 507.22,
      "text": "Няма да се ставим с това."
    },
    {
      "start": 507.22,
      "end": 511.44,
      "text": "Небе, дай всеки да си ги напише по-добре."
    },
    {
      "start": 511.44,
      "end": 518.1,
      "text": "Днес бюлетина на 19."
    },
    {
      "start": 518.1,
      "end": 526.02,
      "text": "Ако искаш ЕГН, ето там на мен."
    },
    {
      "start": 526.02,
      "end": 528.02,
      "text": "Може ли да се приеме бюлетина?"
    },
    {
      "start": 528.02,
      "end": 562.69,
      "text": "Съвждат, че пишат."
    },
    {
      "start": 562.69,
      "end": 593.71,
      "text": "8 за, 1 против и там ще си напишем имената."
    },
    {
      "start": 593.71,
      "end": 599.32,
      "text": "Не. Зах да се опускане колко човека?"
    },
    {
      "start": 599.32,
      "end": 601.6,
      "text": "Аз съм Зах, а ти Асен."
    },
    {
      "start": 601.6,
      "end": 610.11,
      "text": "Ама. Три ма. Четири. Шест. Седем. Осем."
    },
    {
      "start": 610.11,
      "end": 612.11,
      "text": "Аз не съм се браскал, че това се браскал."
    },
    {
      "start": 612.11,
      "end": 614.11,
      "text": "Осем на едно."
    },
    {
      "start": 614.11,
      "end": 616.24,
      "text": "Еми, хубаво де."
    },
    {
      "start": 616.24,
      "end": 618.24,
      "text": "Аз съм Поревосна."
    },
    {
      "start": 618.24,
      "end": 620.24,
      "text": "Разбира се, че сам Поревосна."
    },
    {
      "start": 620.24,
      "end": 642.01,
      "text": "Точно, да знаеш."
    },
    {
      "start": 642.01,
      "end": 648.52,
      "text": "Ти има на това."
    },
    {
      "start": 648.52,
      "end": 651.54,
      "text": "Неясен хикс. Гласували за..."
    },
    {
      "start": 651.54,
      "end": 717.64,
      "text": "Една с преференция."
    },
    {
      "start": 717.64,
      "end": 751.04,
      "text": "Бюллетина е гласувана с знак В за партията."
    },
    {
      "start": 751.04,
      "end": 756.04,
      "text": "Неясен знак, точка, заповядно броем само партията."
    },
    {
      "start": 756.04,
      "end": 758.04,
      "text": "Без преференция."
    },
    {
      "start": 758.04,
      "end": 766.6,
      "text": "Я виждат ли са?"
    },
    {
      "start": 766.6,
      "end": 769.2,
      "text": "Чакай."
    },
    {
      "start": 769.2,
      "end": 774.34,
      "text": "Да, сега."
    },
    {
      "start": 774.34,
      "end": 781.04,
      "text": "Следващия."
    },
    {
      "start": 781.04,
      "end": 785.28,
      "text": "Продължаваме си."
    },
    {
      "start": 785.28,
      "end": 1984.88,
      "text": "Благодаря ви, че гледахте тази екран."
    }
