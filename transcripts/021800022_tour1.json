    {
      "start": 15.24,
      "end": 17.42,
      "text": "Остройството не е позиционирано правилно."
    },
    {
      "start": 17.86,
      "end": 19.92,
      "text": "Завъртете го така, че физическите бутони"
    },
    {
      "start": 19.92,
      "end": 20.82,
      "text": "да бъдат отгоре."
    },
    {
      "start": 20.82,
      "end": 21.12,
      "text": "..."
    },
    {
      "start": 21.12,
      "end": 22.82,
      "text": "..."
    },
    {
      "start": 22.82,
      "end": 24.82,
      "text": "..."
    },
    {
      "start": 98.56,
      "end": 100.56,
      "text": "Добре, шегна."
    },
    {
      "start": 105.56,
      "end": 108.56,
      "text": "Трябва да бъдеш и приютални, че това е."
    },
    {
      "start": 110.01,
      "end": 111.01,
      "text": "И прави да е така?"
    },
    {
      "start": 111.01,
      "end": 113.01,
      "text": "Около така да е, аз така не си."
    },
    {
      "start": 119.68,
      "end": 140.02,
      "text": "Също прави. Само, че го държали."
    },
    {
      "start": 140.02,
      "end": 142.3,
      "text": "Не, няма да върши рао."
    },
    {
      "start": 146.96,
      "end": 152.31,
      "text": "Пътите да виждат."
    },
    {
      "start": 153.31,
      "end": 155.31,
      "text": "Виждат какво стане."
    },
    {
      "start": 155.31,
      "end": 157.31,
      "text": "Не става, да?"
    },
    {
      "start": 157.31,
      "end": 159.31,
      "text": "Дай да го подпрем."
    },
    {
      "start": 159.31,
      "end": 161.31,
      "text": "На шише, чакай. И тук на шише."
    },
    {
      "start": 161.31,
      "end": 163.31,
      "text": "Шишето отзад и нито ми и друг."
    },
    {
      "start": 163.31,
      "end": 165.31,
      "text": "Това вижте останва пак в ръката ни."
    },
    {
      "start": 165.31,
      "end": 167.31,
      "text": "Кой е това?"
    },
    {
      "start": 167.31,
      "end": 169.31,
      "text": "Снимки."
    },
    {
      "start": 169.31,
      "end": 171.31,
      "text": "Вижте, ще те приедем отзади."
    },
    {
      "start": 171.31,
      "end": 173.31,
      "text": "Ето и."
    },
    {
      "start": 173.31,
      "end": 175.31,
      "text": "Чакай, по-лияко е."
    },
    {
      "start": 175.31,
      "end": 177.31,
      "text": "Чакай."
    },
    {
      "start": 177.31,
      "end": 179.6,
      "text": "Ето и ако подпрем."
    },
    {
      "start": 179.6,
      "end": 181.6,
      "text": "Па да настъпнете."
    },
    {
      "start": 181.6,
      "end": 183.6,
      "text": "Дай ще я подпрем."
    },
    {
      "start": 183.6,
      "end": 185.79,
      "text": "Да не съвиждаш випса на камерата."
    },
    {
      "start": 185.79,
      "end": 187.79,
      "text": "Какво виждаш випса на камерата?"
    },
    {
      "start": 187.79,
      "end": 189.79,
      "text": "Как съм виждал е?"
    },
    {
      "start": 189.79,
      "end": 191.79,
      "text": "Ей той!"
    },
    {
      "start": 191.79,
      "end": 193.79,
      "text": "Майор Трада е, да."
    },
    {
      "start": 193.79,
      "end": 196.27,
      "text": "Ей той, ще си дзи."
    },
    {
      "start": 196.27,
      "end": 198.27,
      "text": "А, обаче малко трябва да го си дай."
    },
    {
      "start": 198.27,
      "end": 200.27,
      "text": "Забърся с това да..."
    },
    {
      "start": 200.27,
      "end": 202.27,
      "text": "Ей така малко. Цял са ли?"
    },
    {
      "start": 202.27,
      "end": 204.27,
      "text": "Да фашта маса."
    },
    {
      "start": 204.27,
      "end": 206.27,
      "text": "Да не мислиш сега кой знае к'во."
    },
    {
      "start": 206.27,
      "end": 208.27,
      "text": "Да фашта маса."
    },
    {
      "start": 208.27,
      "end": 210.27,
      "text": "Виждали съм."
    },
    {
      "start": 210.27,
      "end": 212.27,
      "text": "Да не съйме Михоя Левицки фил."
    },
    {
      "start": 212.88,
      "end": 214.88,
      "text": "Да, аз не мисля, че това не е нещо."
    },
