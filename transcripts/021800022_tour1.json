    {
      "start": 2339.47,
      "end": 2341.47,
      "text": "Двести, шести и осеми са с образ."
    },
    {
      "start": 2341.47,
      "end": 2452.11,
      "text": "Готово."
    },
    {
      "start": 2452.11,
      "end": 2464.8,
      "text": "Семнайсет и очки."
    },
    {
      "start": 2464.8,
      "end": 2578.64,
      "text": "Двести номер."
    },
    {
      "start": 2578.64,
      "end": 2584.67,
      "text": "Биограм сега са стои двайсет."
    },
    {
      "start": 2584.67,
      "end": 2592.5,
      "text": "Майшен пяна."
    },
    {
      "start": 2592.5,
      "end": 2601.82,
      "text": "Семнайсет и номер."
    },
    {
      "start": 2601.82,
      "end": 2736.27,
      "text": "Какво има да ми пройде?"
    },
    {
      "start": 2736.27,
      "end": 2766.02,
      "text": "Двайсет и едно."
    },
    {
      "start": 2766.02,
      "end": 2770.9,
      "text": "Пет и петат."
    },
    {
      "start": 2770.9,
      "end": 2827.97,
      "text": "Двайсет и малек."
    },
    {
      "start": 2827.97,
      "end": 2869.42,
      "text": "Пет и четири."
    },
    {
      "start": 2869.42,
