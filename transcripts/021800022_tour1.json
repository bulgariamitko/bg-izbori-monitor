    },
    {
      "start": 15.25,
      "end": 17.41,
      "text": "Остройството не е позиционирано правилно."
    },
    {
      "start": 17.85,
      "end": 20.81,
      "text": "Завъртете го така, че физическите бутони да бъдат отгоре."
    },
    {
      "start": 30.96,
      "end": 32.96,
      "text": "Чакай!"
    },
    {
      "start": 32.96,
      "end": 35.02,
      "text": "Така."
    },
    {
      "start": 37.5,
      "end": 39.5,
      "text": "Да."
    },
    {
      "start": 44.58,
      "end": 68.05,
      "text": "Да."
    },
    {
      "start": 68.05,
      "end": 70.11,
      "text": "Сканирам ли?"
    },
    {
      "start": 70.11,
      "end": 72.11,
      "text": "Това е пазлът."
    },
    {
      "start": 72.11,
      "end": 74.11,
      "text": "Записва."
    },
    {
      "start": 74.11,
      "end": 78.29,
      "text": "Сега бачки не може да ги направи,"
    },
    {
      "start": 78.29,
      "end": 80.29,
      "text": "защото трябва някакво да се отреже."
    },
    {
      "start": 80.29,
      "end": 95.95,
      "text": "Ела, бръш!"
    },
    {
      "start": 126.27,
      "end": 128.27,
      "text": "Ама това трябва да е някакво."
    },
    {
      "start": 128.27,
      "end": 130.27,
      "text": "За това трябва някой да го гледа отзад."
    },
    {
      "start": 130.27,
      "end": 132.27,
      "text": "Защото не се вижда отвред."
    },
    {
      "start": 132.27,
      "end": 134.27,
      "text": "А, дай-ле, дай-ле."
    },
    {
      "start": 134.27,
      "end": 136.27,
      "text": "Ама така, ще може ли да стои?"
    },
    {
      "start": 136.27,
      "end": 138.27,
      "text": "Не, не може да стои."
    },
    {
      "start": 138.27,
      "end": 140.66,
      "text": "Хори, аз какво ще правя? Само ще го държа ли?"
    },
    {
      "start": 140.66,
      "end": 143.26,
      "text": "Няма ли да върша работа?"
    },
    {
      "start": 143.26,
      "end": 146.45,
      "text": "Да, казвам."
    },
    {
      "start": 146.45,
      "end": 148.45,
      "text": "Ей отидете, соните отидете да видите."
    },
    {
      "start": 148.45,
      "end": 154.51,
      "text": "Вижте това какво стане."
    },
    {
      "start": 154.51,
      "end": 156.83,
      "text": "Не става, бе."
    },
    {
      "start": 156.83,
      "end": 160.75,
      "text": "На шише, чакай, и тук на шише."
    },
    {
      "start": 160.75,
      "end": 162.75,
      "text": "Шишето отзад и нито."
    },
    {
      "start": 162.75,
      "end": 164.91,
      "text": "Това вижте, останва пак в ръката ни."
    },
    {
      "start": 164.91,
      "end": 166.91,
      "text": "Кой е това?"
    },
    {
      "start": 166.91,
      "end": 168.91,
      "text": "Снимки."
    },
    {
      "start": 168.91,
      "end": 170.91,
      "text": "Ето и."
    },
    {
      "start": 170.91,
      "end": 173.01,
      "text": "Ето и."
    },
    {
      "start": 173.01,
      "end": 175.01,
      "text": "Чакай, поне ядовият ми е това."
    },
    {
      "start": 175.01,
      "end": 177.01,
      "text": "Чакай."
    },
    {
      "start": 177.01,
      "end": 179.97,
      "text": "Ето и, ако подпрем."
    },
    {
      "start": 179.97,
      "end": 181.97,
      "text": "Първен настъпни."
    },
    {
      "start": 181.97,
      "end": 183.97,
      "text": "Дай швеп, че смятаме едно голямо."
    },
    {
      "start": 183.97,
      "end": 186.29,
      "text": "Не знам вижда ли швеп са на камерата."
    },
    {
      "start": 186.29,
      "end": 188.29,
      "text": "Как съм виждал."
    },
    {
      "start": 188.29,
      "end": 190.29,
      "text": "Ето и."
    },
    {
      "start": 190.29,
      "end": 192.29,
      "text": "Ето и."
    },
    {
      "start": 192.29,
      "end": 194.29,
      "text": "Ето и."
    },
    {
      "start": 194.29,
      "end": 196.96,
      "text": "Ей той, ще седи."
    },
    {
      "start": 196.96,
      "end": 198.96,
      "text": "Та обаче малко трябва да го се прави."
    },
    {
      "start": 198.96,
      "end": 200.96,
      "text": "Вижте, чакай."
    },
    {
      "start": 200.96,
      "end": 203.15,
      "text": "Е така малко. Цял са ли?"
    },
    {
      "start": 203.15,
      "end": 205.15,
      "text": "Да фашта масата."
    },
    {
      "start": 205.15,
      "end": 207.15,
      "text": "Да не мислиш, кой знае какво е."
    },
    {
      "start": 207.15,
      "end": 209.15,
      "text": "Виждали се?"
    },
    {
      "start": 209.15,
      "end": 211.15,
      "text": "Не виждаше ми."
    },
    {
      "start": 211.15,
      "end": 213.15,
      "text": "То да не си има Николи Бъцки филм."
    },
    {
      "start": 213.15,
      "end": 215.15,
      "text": "Камерата не са, защото камерата ще бъде останала."
    },
    {
      "start": 215.15,
      "end": 217.15,
      "text": "Трябва да си си си си."
    },
    {
      "start": 225.15,
      "end": 227.28,
      "text": "Благодаря."
    }
  ],
