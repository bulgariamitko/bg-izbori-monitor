    {
      "start": 5444.93,
      "end": 5448.46,
      "text": "Пет и шест страни."
    },
    {
      "start": 5448.46,
      "end": 5584.29,
      "text": "И си, че си, че си."
    },
    {
      "start": 5584.29,
      "end": 5589.11,
      "text": "Тук без преференция, това беше много."
    },
    {
      "start": 5589.11,
      "end": 5612.2,
      "text": "Аз съм виксел, да той бъде в преференция."
    },
    {
      "start": 5612.2,
      "end": 5636.5,
      "text": "И че бе ли да..."
