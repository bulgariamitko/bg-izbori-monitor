      "text": "Той няма да се подпише на бригота."
    },
    {
      "start": 7310.09,
      "end": 7362.04,
      "text": "Това е на като дали си била тук."
    },
    {
      "start": 7362.04,
      "end": 7426.57,
      "text": "И жалъм и вярност."
    },
    {
      "start": 7426.57,
      "end": 7439.67,
      "text": "Сега сме ще се печат по печата."
    },
    {
      "start": 7439.67,
      "end": 7441.67,
      "text": "Ти не ще си бяхме по печата."
    },
    {
      "start": 7441.67,
      "end": 7442.67,
      "text": "Не, още да си печат, аме."
    },
    {
      "start": 7464.4,
