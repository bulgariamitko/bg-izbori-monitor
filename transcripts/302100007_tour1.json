      "text": "Готово."
    },
    {
      "start": 2.0,
      "end": 5.0,
      "text": "Айде, вече се плавим."
    },
    {
      "start": 5.0,
      "end": 7.0,
      "text": "Изкарай карта от тази."
    },
    {
      "start": 7.0,
