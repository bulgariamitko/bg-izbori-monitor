      "text": "Чакай, че вълчат."
    },
    {
      "start": 3615.39,
      "end": 3615.95,
      "text": "Не, не, не, добре."
    },
    {
      "start": 3615.95,
      "end": 3628.09,
      "text": "Това е от тази дравка."
    },
    {
      "start": 3628.09,
      "end": 3629.25,
      "text": "Пакет с надписи."
    },
    {
      "start": 3629.31,
      "end": 3642.11,
      "text": "Трябва да го помините."
    },
    {
      "start": 3642.11,
      "end": 3649.31,
      "text": "И да го разпочиваме."
    },
    {
      "start": 3649.31,
      "end": 3661.64,
      "text": "Това е пътият."
    },
    {
      "start": 3661.64,
      "end": 3662.64,
      "text": "Така, къде ще се подвижат?"
    },
    {
      "start": 3673.9,
      "end": 3674.9,
      "text": "В куча?"
    },
    {
      "start": 3674.9,
      "end": 3698.46,
      "text": "В куча е всеки 6."
    },
    {
      "start": 3698.46,
      "end": 3701.99,
      "text": "Това?"
    },
    {
      "start": 3701.99,
      "end": 3702.99,
      "text": "Това е неспектна трошка."
    },
    {
      "start": 3702.99,
      "end": 3703.99,
      "text": "И оверяйте право много и кажете, че е."
    },
    {
      "start": 3703.99,
      "end": 3718.08,
      "text": "Къде ще се подвижат?"
    },
    {
      "start": 3718.08,
      "end": 3719.08,
      "text": "Аз може би ти ги съберем и да кажем."
    },
    {
      "start": 3719.08,
      "end": 3720.08,
      "text": "Това е това."
    },
    {
      "start": 3720.08,
      "end": 3721.08,
      "text": "Това е това."
    },
    {
      "start": 3721.08,
      "end": 3722.56,
      "text": "Ти ги кучани бъдете ли няма?"
    },
    {
      "start": 3722.56,
      "end": 3723.56,
      "text": "Няма."
    },
    {
      "start": 3723.56,
      "end": 3724.56,
      "text": "Не използваме."
    },
    {
      "start": 3724.56,
      "end": 3746.78,
      "text": "Какво е това?"
    },
    {
      "start": 3746.78,
      "end": 3747.78,
      "text": "Ти ги бъдете ли няма?"
    },
    {
      "start": 3747.78,
      "end": 3748.78,
      "text": "Това всичко, всичко не е на трешата."
    },
    {
      "start": 3748.78,
      "end": 3750.1,
      "text": "Всичко не е на трешата."
    },
    {
      "start": 3750.1,
      "end": 3753.58,
      "text": "Ако тук бъдете отключени в половината и дотоа,"
    },
    {
      "start": 3753.58,
      "end": 3771.3,
      "text": "ще станете ища в среща по-късни."
    },
    {
      "start": 3771.3,
      "end": 3797.39,
      "text": "Къде останат?"
    },
    {
      "start": 3797.39,
      "end": 3861.88,
      "text": "11."
    },
    {
      "start": 3861.88,
      "end": 3922.25,
      "text": "Напиши го."
    },
    {
      "start": 3922.25,
      "end": 3939.32,
      "text": "Колко?"
    },
    {
      "start": 3939.32,
      "end": 3943.85,
      "text": "По избирателния списък."
    },
    {
      "start": 3943.85,
      "end": 3949.37,
      "text": "Пиши колко са готворителни."
    },
    {
      "start": 3949.37,
      "end": 3956.64,
      "text": "98."
    },
    {
      "start": 3956.64,
      "end": 3961.69,
      "text": "Значит, по избирателния списък избирателите."
    },
    {
      "start": 3961.69,
      "end": 3964.69,
      "text": "802, 804."
    },
    {
      "start": 3964.69,
      "end": 3968.39,
      "text": "От тях 6 за лечение,"
    },
    {
      "start": 4495.03,
      "end": 4546.64,
      "text": "Ние го си спишем някакви неизползвани бюлетини."
    },
    {
      "start": 4546.64,
      "end": 4547.64,
      "text": "Снаби, бюлетини."
    },
    {
      "start": 4547.64,
      "end": 4551.07,
      "text": "Хикши."
    },
    {
      "start": 4551.07,
      "end": 4552.07,
      "text": "Хикши."
    },
    {
      "start": 4552.07,
      "end": 4558.0,
      "text": "Меден бързин."
    },
    {
      "start": 4558.0,
      "end": 4559.8,
      "text": "Меден бързин."
    },
    {
      "start": 4559.8,
      "end": 4568.06,
      "text": "Меден бързин."
    },
    {
      "start": 4568.06,
      "end": 4569.06,
      "text": "Те са билетни?"
    },
    {
      "start": 4569.06,
      "end": 4581.42,
      "text": "Да, и там."
    },
    {
      "start": 4581.42,
      "end": 4582.49,
      "text": "Та е какво?"
    },
    {
      "start": 4582.49,
      "end": 4603.3,
      "text": "Характерно, че е това."
    },
    {
      "start": 4603.3,
      "end": 4605.94,
      "text": "Кога билетната е?"
    },
    {
      "start": 4605.94,
      "end": 4635.58,
      "text": "Обичайно, това си има това."
    },
    {
      "start": 4635.58,
      "end": 4771.69,
      "text": "Неделни години, тя ви сучи там."
    },
    {
      "start": 4771.69,
      "end": 4773.69,
      "text": "И тук, о, хубави се, че са."
    },
    {
      "start": 4773.69,
      "end": 4808.78,
      "text": "Ти направи, но обещава има да ги харати."
    },
    {
      "start": 4808.78,
      "end": 4815.76,
      "text": "Да, си седем."
    },
    {
      "start": 5108.8,
      "end": 5124.72,
      "text": "Нарете е пиши тази."
    },
    {
      "start": 5124.72,
      "end": 5126.72,
      "text": "Това е това, което трябва да пишем там."
    },
    {
      "start": 5126.72,
      "end": 5128.72,
      "text": "Това е тази картинка, която трябва да пишем тук."
    },
    {
      "start": 5128.72,
      "end": 5130.72,
      "text": "Той е нарете."
    },
    {
      "start": 5130.72,
      "end": 5137.33,
      "text": "Отрязаното пишем тук."
    },
    {
      "start": 5137.33,
      "end": 5144.83,
      "text": "И вече трябва тук."
    },
    {
      "start": 5144.83,
      "end": 5146.83,
      "text": "Тук вече трябва тук за маркерен печатър."
    },
    {
      "start": 5146.83,
      "end": 5150.37,
      "text": "Аз ще ви дадя това."
    },
    {
      "start": 5150.37,
      "end": 5177.42,
      "text": "Маркерен печатър."
    },
    {
      "start": 5177.42,
      "end": 5183.9,
      "text": "Вижте какво споят."
    },
    {
      "start": 5183.9,
      "end": 5236.18,
      "text": "Питък Валя каза, остарам тази,"
    },
    {
      "start": 5236.18,
      "end": 5249.7,
      "text": "а тук дете няма нищо."
    },
    {
      "start": 5249.7,
      "end": 5252.69,
      "text": "Денай си тази."
    },
    {
      "start": 5252.69,
      "end": 5257.06,
      "text": "Трябва да се подсипне."
    },
    {
      "start": 5257.06,
      "end": 5301.6,
      "text": "8 и 1 евро."
    },
    {
      "start": 5303.66,
      "end": 5304.14,
      "text": "Без хора."
    },
    {
      "start": 5304.14,
      "end": 5304.38,
      "text": "Няма."
    },
    {
      "start": 5304.82,
      "end": 5312.24,
      "text": "И латка да търсим по ресурс."
    },
    {
      "start": 5313.7,
      "end": 5314.56,
      "text": "Да печата."
    },
    {
      "start": 5326.6,
      "end": 5327.76,
      "text": "Да не тук не вземе хора."
    },
    {
      "start": 5328.04,
      "end": 5352.62,
      "text": "Тъй печата от..."
    },
    {
      "start": 5352.62,
      "end": 5352.72,
      "text": "Няма."
    },
    {
      "start": 5353.65,
      "end": 5354.67,
      "text": "Та ще са да наметим."
    },
    {
      "start": 5372.74,
      "end": 5373.16,
      "text": "Там бъде."
    },
    {
      "start": 5373.44,
      "end": 5399.66,
      "text": "Тъй удоволен."
    },
    {
      "start": 5399.9,
      "end": 5406.74,
      "text": "Това е десет."
    },
    {
      "start": 5409.67,
      "end": 5410.41,
      "text": "По зуба."
    },
    {
      "start": 5410.51,
      "end": 5411.21,
      "text": "Ти не печата."
    },
    {
      "start": 5415.23,
      "end": 5416.37,
      "text": "Те ти екземиарно."
    },
    {
      "start": 5416.89,
      "end": 5417.93,
      "text": "Тук да не е лъсно."
    },
    {
      "start": 5418.09,
      "end": 5418.29,
      "text": "Това е хора."
    },
    {
      "start": 5418.41,
      "end": 5418.91,
      "text": "Това е хора."
    },
    {
      "start": 5419.11,
      "end": 5420.29,
      "text": "Ти не се екземиарно."
    },
    {
      "start": 5420.69,
      "end": 5423.14,
      "text": "Това е хора."
    },
    {
      "start": 5423.82,
      "end": 5462.84,
      "text": "Че, няма хора."
    },
    {
      "start": 5462.84,
      "end": 5463.24,
      "text": "Това е десет."
    },
    {
      "start": 5463.7,
      "end": 5464.68,
      "text": "Ще я сложим при виската."
    },
    {
      "start": 5704.57,
      "end": 5894.78,
      "text": "15, 24, 35, 54, 58, 62, 62, 43, 44, 45, 46, 45, 46, 47, 48, 41, 42, 43, 44, 45, 46, 49, 50."
    },
    {
      "start": 5894.8,
      "end": 6502.44,
      "text": "Трябва да ти ще тръгваме."
    },
    {
      "start": 6502.46,
      "end": 6527.33,
      "text": "Къде си няма?"
    },
    {
      "start": 6527.33,
      "end": 6597.46,
      "text": "Вижте ли копия?"
    },
    {
      "start": 6597.46,
      "end": 6599.46,
      "text": "И аз ще дем от портфола."
    },
    {
      "start": 6599.46,
      "end": 6600.46,
      "text": "7 на 5."
    },
    {
      "start": 6600.46,
      "end": 6610.52,
      "text": "Четът копия."
    },
    {
      "start": 6610.52,
      "end": 6630.34,
      "text": "Да, да, да, да."
    },
    {
      "start": 6630.34,
      "end": 6632.72,
      "text": "Търпи се кае, да се кае."
    },
    {
      "start": 6632.72,
      "end": 6706.79,
      "text": "Ано, срещна номера."
    },
    {
      "start": 6706.79,
      "end": 6724.15,
      "text": "Това трябва да е питрявката с два паса."
    },
    {
      "start": 6724.15,
      "end": 6727.17,
      "text": "Това е си изкарали."
    },
    {
      "start": 6727.17,
      "end": 6732.3,
      "text": "Не е."
    },
    {
      "start": 6732.3,
      "end": 6733.3,
      "text": "Търпи."
    },
    {
      "start": 6733.3,
      "end": 6734.3,
      "text": "Вижте да ви виждате."
    },
    {
      "start": 6734.3,
      "end": 6738.24,
      "text": "Отега, вижте."
    },
    {
      "start": 6738.24,
      "end": 6774.0,
      "text": "Ей, да ви чакам."
    },
    {
      "start": 6774.0,
      "end": 6800.5,
      "text": "Ей, кае."
    },
    {
      "start": 6800.5,
      "end": 6840.51,
      "text": "Трябва да ви виждате."
    },
    {
      "start": 6840.51,
      "end": 6851.88,
      "text": "Това е чето и от тук."
    },
    {
      "start": 6851.88,
      "end": 6854.7,
      "text": "Иде за да ви чекате."
    },
    {
      "start": 7403.74,
      "end": 7451.62,
      "text": "Ни, не е."
    },
    {
      "start": 7499.88,
      "end": 7568.07,
      "text": "Нема бутилка, аз се еднам фагава, ще отчарзвам това на родника."
    },
    {
      "start": 7568.07,
      "end": 7569.07,
      "text": "Разбира се, ще бъде."
    },
    {
      "start": 7569.07,
      "end": 7600.71,
      "text": "Некога не състоя и получи какъв избрателният списък."
    },
    {
      "start": 7600.71,
      "end": 7604.66,
      "text": "За това допълнително присядем."
    },
    {
      "start": 7604.66,
      "end": 7606.36,
      "text": "Да, да, да."
    },
    {
      "start": 7606.36,
      "end": 7608.13,
      "text": "Всичко е."
    },
    {
      "start": 7669.23,
      "end": 7672.08,
      "text": "Маме една.."
    },
    {
      "start": 7673.08,
      "end": 7680.32,
      "text": "Тежка."
    },
    {
      "start": 7680.32,
      "end": 7681.9,
      "text": "Копия на черновата."
    },
    {
      "start": 7681.9,
      "end": 7686.27,
      "text": "Сега трябва да припочи."
    },
    {
      "start": 7686.27,
      "end": 7690.4,
      "text": "Иска в комплината ми."
    },
    {
      "start": 7690.4,
      "end": 7691.4,
      "text": "Що е в гоббой?"
    },
    {
      "start": 7691.4,
      "end": 7712.16,
      "text": "Ето това, чарен младочет."
    },
    {
      "start": 7712.16,
      "end": 7716.93,
      "text": "Маме младочет."
    },
    {
      "start": 7716.93,
      "end": 7733.96,
      "text": "Ека ли е?"
    },
    {
      "start": 7733.96,
      "end": 7734.96,
      "text": "Чарен свам."
    },
    {
      "start": 7734.96,
      "end": 7870.36,
      "text": "Пиши това."
    },
    {
      "start": 7870.36,
      "end": 7871.78,
      "text": "Какво си има?"
    },
    {
      "start": 7871.78,
      "end": 7872.78,
      "text": "Белата хартияна."
    },
    {
      "start": 7872.78,
      "end": 7877.4,
      "text": "Хартияна, да."
    },
    {
      "start": 7877.4,
      "end": 7902.2,
      "text": "Просто пиши че бе..."
    },
    {
      "start": 7902.2,
      "end": 7962.53,
      "text": "Записваме това."
    },
    {
      "start": 7962.53,
      "end": 7965.53,
      "text": "Си вече е периода на обявяне на преключване на състояние на..."
    },
    {
      "start": 7965.53,
      "end": 7976.45,
      "text": "Се извършват в периода от обявяване на гласуването за преключване до съставяне, включено подписване на протоколите на секционната избирателна комисия."
    },
    {
      "start": 7976.45,
      "end": 7977.45,
      "text": "Добре, добре."
    },
    {
      "start": 7977.45,
      "end": 7978.74,
      "text": "Добре, добре."
    },
    {
      "start": 7978.74,
      "end": 7984.76,
      "text": "Добре."
    },
    {
      "start": 7984.76,
      "end": 7986.76,
      "text": "Ти трябва да дойш да го спреши."
    },
    {
      "start": 7986.76,
      "end": 7988.98,
      "text": "Моля?"
    },
    {
      "start": 7991.04,
      "end": 7992.04,
      "text": "Дей се."
    },
    {
      "start": 9101.48,
      "end": 9103.73,
      "text": "Ха-ха-ха!"
    }
