    },
    {
      "start": 158.8,
      "end": 169.66,
      "text": "Деденас. 120 плюс едно."
    },
    {
      "start": 169.66,
      "end": 171.66,
      "text": "Да."
    },
    {
      "start": 171.66,
      "end": 173.66,
      "text": "120 плюс 21 е."
    },
    {
      "start": 173.66,
      "end": 301.81,
      "text": "Как са върху?"
    },
    {
      "start": 301.81,
      "end": 305.25,
      "text": "Едно седем."
    },
    {
      "start": 305.25,
      "end": 322.67,
      "text": "Давай другият."
    },
    {
      "start": 322.67,
      "end": 341.02,
      "text": "Това е то."
    },
    {
      "start": 341.02,
      "end": 344.85,
      "text": "Летко."
    },
    {
      "start": 344.85,
      "end": 346.85,
      "text": "Канцеларските възема..."
    },
    {
      "start": 346.85,
      "end": 348.85,
      "text": "Черния джоа."
    },
    {
      "start": 348.85,
      "end": 350.85,
      "text": "Черния да?"
    },
    {
      "start": 350.85,
      "end": 352.85,
      "text": "Као е си къде? Защо там?"
    },
    {
      "start": 352.85,
      "end": 360.61,
      "text": "Да, дай някакъв момент."
    },
    {
      "start": 360.61,
      "end": 367.15,
      "text": "Добре, тръгай."
    },
    {
      "start": 367.15,
      "end": 369.28,
      "text": "Силуа, да не..."
    },
    {
      "start": 369.28,
      "end": 372.21,
      "text": "Това ще ви пишем."
    },
    {
      "start": 372.21,
      "end": 374.21,
      "text": "Не, други мъжи. Ето да ще пишем."
    },
    {
      "start": 374.21,
      "end": 448.78,
      "text": "Тук са си и тази."
    },
    {
      "start": 448.78,
      "end": 451.46,
      "text": "Да, и плътна си има."
    },
    {
      "start": 451.46,
      "end": 453.46,
      "text": "Плътна си са."
    },
    {
      "start": 453.46,
      "end": 504.32,
      "text": "А, и като бъде имал едно..."
    },
    {
      "start": 504.32,
      "end": 661.07,
      "text": "Зал."
    },
    {
      "start": 661.07,
      "end": 663.07,
      "text": "И ще оставя сега."
    },
    {
      "start": 663.07,
      "end": 921.36,
      "text": "И аз като и принош."
    },
    {
      "start": 921.36,
      "end": 1129.09,
      "text": "Ти нямаш само едно."
    },
    {
      "start": 1129.09,
      "end": 1147.3,
      "text": "И ти едно. Едно, едно. 15, но 25 препаренти."
    },
    {
      "start": 1147.3,
      "end": 1163.81,
      "text": "Да, една препаренти."
    },
    {
      "start": 1163.81,
      "end": 1257.23,
      "text": "Ти ще го редя десет."
    },
    {
      "start": 1257.23,
      "end": 1342.78,
      "text": "Ти си да пишем, али?"
    },
    {
      "start": 1342.78,
      "end": 1378.48,
      "text": "Да, 25."
    },
    {
      "start": 1378.48,
      "end": 1516.29,
      "text": "Ето като е. Е равно на?"
    },
    {
      "start": 1516.29,
      "end": 1521.33,
      "text": "Аз се..."
    },
    {
      "start": 1521.33,
      "end": 1537.09,
      "text": "Че е реферал?"
    },
    {
      "start": 1537.09,
      "end": 1542.93,
      "text": "Печатат твоите лошери."
    },
    {
      "start": 1542.93,
      "end": 1558.34,
      "text": "Печатат лошките и карти сте по..."
    },
    {
      "start": 1558.34,
      "end": 1559.34,
      "text": "А?"
    },
    {
      "start": 1559.34,
      "end": 1569.02,
      "text": "Я ми ви ще спит едно, какво има."
    },
    {
      "start": 1569.02,
      "end": 1600.71,
      "text": "Декларации и документи."
    },
    {
      "start": 1600.71,
      "end": 1601.71,
      "text": "Това ще опишем с тук."
    },
    {
      "start": 1601.71,
      "end": 1604.09,
      "text": "Те са..."
    },
    {
      "start": 1604.09,
      "end": 1605.09,
      "text": "Е, те са опишени да се опишат."
    },
    {
      "start": 1605.09,
      "end": 1607.09,
      "text": "... в протоколната медиа."
    },
    {
      "start": 1607.09,
      "end": 1608.89,
      "text": "Плашките?"
    },
    {
      "start": 1608.89,
      "end": 1609.89,
      "text": "Са печатени плашки."
    },
    {
      "start": 1609.89,
      "end": 1610.89,
      "text": "Пет смарт-карти."
    },
    {
      "start": 1610.89,
      "end": 1611.89,
      "text": "Добре."
    },
    {
      "start": 1611.89,
      "end": 1612.89,
      "text": "И нарено в четвъртима камършни..."
    },
    {
      "start": 1612.89,
      "end": 1613.89,
      "text": "ало е ли аз си прописан?"
    },
    {
      "start": 1613.89,
      "end": 1622.22,
      "text": "Не, аз се давам ниво 70..."
    },
    {
      "start": 1622.22,
      "end": 1623.22,
      "text": "Ало аз се разпишеш..."
    },
    {
      "start": 1623.22,
      "end": 1624.22,
      "text": "да опишем."
    },
    {
      "start": 1624.22,
      "end": 1632.42,
      "text": "Добро."
    },
    {
      "start": 1632.42,
      "end": 1633.42,
      "text": "Даги е."
    },
    {
      "start": 1633.42,
      "end": 1650.77,
      "text": "Благодаря, че са запишени."
    },
    {
      "start": 1650.77,
      "end": 1680.66,
      "text": "Добро."
    },
    {
      "start": 1680.66,
      "end": 1727.49,
      "text": "... и си трябва да се печатат в плашките."
    },
    {
      "start": 1727.49,
      "end": 1755.56,
      "text": "Аз се разбиш."
    },
    {
      "start": 1755.56,
      "end": 1756.56,
      "text": "Най-борънно."
    },
    {
      "start": 1756.56,
      "end": 1779.54,
      "text": "... като му са да кондаси пари-палети, петеха, аки, нарин от чет."
    },
    {
      "start": 1779.54,
      "end": 1783.9,
      "text": "Няма ли от чет платка?"
    },
    {
      "start": 1783.9,
      "end": 1784.9,
      "text": "Да."
    },
    {
      "start": 1784.9,
      "end": 1802.97,
      "text": "Какво зададете и си седем от това?"
    },
    {
      "start": 1802.97,
      "end": 1803.97,
      "text": "Не ми е бързо."
    },
    {
      "start": 1803.97,
      "end": 1814.98,
      "text": "Това е от седем, кажи."
    },
    {
      "start": 1814.98,
      "end": 1869.17,
      "text": "Четървата е в това, а черновата, самата черновата е нарисана на чет."
    },
    {
      "start": 1869.17,
      "end": 1870.17,
      "text": "Няма ли от чет платка?"
    },
    {
      "start": 1870.17,
      "end": 1921.51,
      "text": "И си демети и едно държито от тази."
    },
    {
      "start": 1921.51,
      "end": 1923.57,
      "text": "Какво също демети са?"
    },
    {
      "start": 1923.57,
      "end": 1925.69,
      "text": "Това е ли..."
    },
    {
      "start": 1925.69,
      "end": 1932.32,
      "text": "Нето ти е възможно ли това?"
    },
    {
      "start": 1932.32,
      "end": 1935.94,
      "text": "Аз съм малко не съм съборен."
    },
    {
      "start": 1935.94,
      "end": 2042.06,
      "text": "Да, да, спирай!"
    }
